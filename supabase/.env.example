# ─────────────────────────────────────────────────────────────────────────────
# Supabase — copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────────────────────────────────────

# Project URL — from Supabase dashboard → Settings → API
# Local dev:  http://127.0.0.1:54321
# Production: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Anon (public) key — safe to expose in the browser; RLS is your security layer
# Local dev:  run `supabase status` to get this value
# Production: Supabase dashboard → Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — NEVER expose in browser / client code
# Only used in server-side code (Route Handlers, Server Actions, Edge Functions)
# Local dev:  run `supabase status` to get this value
# Production: Supabase dashboard → Settings → API → Project API keys → service_role secret
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────────────────────

# Canonical URL of the deployed app — used for og:url, canonical tags, redirects
# Local dev:  http://localhost:3000
# Production: https://wimc.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Razorpay (payments)
# ─────────────────────────────────────────────────────────────────────────────

# Public key — safe to use in the browser Razorpay checkout widget
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Secret key — server-side only (order creation, payment capture verification)
RAZORPAY_KEY_SECRET=

# Webhook secret — verify Razorpay webhook signatures in Route Handlers
RAZORPAY_WEBHOOK_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# SMS / OTP
# ─────────────────────────────────────────────────────────────────────────────

# Legacy Twilio provider config (Supabase Dashboard → Auth → Providers → Phone).
# Being replaced by the MSG91 Send SMS Hook below — confirm in the Dashboard
# whether Twilio is still the active provider before removing this.
SUPABASE_AUTH_SMS_TWILIO_AUTH_TOKEN=

# Supabase "Send SMS" Auth Hook — verifies requests to
# /api/webhooks/send-sms genuinely came from Supabase (Standard Webhooks
# signature). Get this from Supabase Dashboard → Auth → Hooks → Send SMS hook
# → Secrets, after pointing the hook at the deployed endpoint URL.
SEND_SMS_HOOK_SECRET=

# MSG91 (SMS delivery for the Send SMS hook — replaces Twilio for Indian numbers)
# Auth Key: MSG91 dashboard → API
MSG91_AUTH_KEY=
# DLT-approved 6-character sender ID
MSG91_SENDER_ID=
# DLT-approved Flow/template ID for the OTP SMS template
MSG91_OTP_TEMPLATE_ID=
# The variable name used inside that DLT template (whatever you named it when
# creating the template in MSG91, e.g. "OTP" or "VAR1")
MSG91_OTP_TEMPLATE_VAR=

# ─────────────────────────────────────────────────────────────────────────────
# Optional — Supabase Studio AI autocomplete
# ─────────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=
